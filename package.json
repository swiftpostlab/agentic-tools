{
  "name": "agentic-tools",
  "version": "0.1.0",
  "description": "Shared agent skills and CLI tools for Node-based repositories.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agentic-tools": "./scripts/agentic-tools.mts",
    "agents-policy": "./scripts/agents-policy.mts",
    "agents-policy-import-vscode": "./scripts/agents-policy-import-vscode.mts",
    "skills-management": "./scripts/skills-management.mts"
  },
  "files": [
    ".agents/skills",
    "scripts/*.mts",
    "src/agentic_tools/main.ts",
    "src/agentic_tools/node_cli/common.ts",
    "src/agentic_tools/agents_policy/main.ts",
    "src/agentic_tools/skills_management/main.ts",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "test:node": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.mjs --runInBand",
    "pack:node": "npm pack --dry-run"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "consola": "^3.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
